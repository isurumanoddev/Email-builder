# AI vision provider (Ollama = free local model, no API key)
AI_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_VISION_MODEL=llava

# Optional: cloud Gemini (set AI_PROVIDER=gemini)
# GEMINI_API_KEY=your_key_here
# GEMINI_MODEL=gemini-2.0-flash

# Figma integration (for AI Import → Figma URL tab)
# Create token: https://help.figma.com/hc/en-us/articles/8085703771159
FIGMA_ACCESS_TOKEN=your_figma_personal_access_token
